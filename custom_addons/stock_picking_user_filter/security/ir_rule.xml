<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Regular users: only see pickings where they are the contact -->
    <record id="stock_picking_personal_rule" model="ir.rule">
        <field name="name">Stock Picking: See Own Only</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Admins: see all pickings -->
    <record id="stock_picking_admin_rule" model="ir.rule">
        <field name="name">Stock Picking: Admin See All</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('stock.group_stock_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
