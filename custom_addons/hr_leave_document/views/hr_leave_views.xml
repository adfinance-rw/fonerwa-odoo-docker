<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit leave form to show document field when required -->
    <record id="view_hr_leave_form_inherit" model="ir.ui.view">
        <field name="name">hr.leave.form.inherit.document</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <!-- Add computed field for document requirement -->
            <field name="leave_type_support_document" position="after">
                <field name="document_required" invisible="1"/>
            </field>

            <!-- Show document upload when document_required is true -->
            <label for="supported_attachment_ids" position="attributes">
                <attribute name="invisible">
                    (not leave_type_support_document and not document_required) or state not in ('confirm', 'validate1')
                </attribute>
            </label>

            <field name="supported_attachment_ids" position="attributes">
                <attribute name="invisible">
                    (not leave_type_support_document and not document_required) or state not in ('confirm', 'validate1')
                </attribute>
            </field>
        </field>
    </record>
</odoo>
